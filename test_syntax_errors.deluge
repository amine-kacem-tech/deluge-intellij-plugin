    // Missing opening brace - should show error
    info "This is a test";

    // Missing semicolon - should show error
    name = "John"

    // Mismatched parentheses
    info "Hello World"

    // Missing closing brace for function - should show error at opening brace


void anotherFunction() {
    // Proper syntax
    info "This is correct";

    // Unclosed parenthesis
