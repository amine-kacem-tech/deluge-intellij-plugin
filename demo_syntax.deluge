// ========== CORRECT SYNTAX EXAMPLES ==========

// Automation function with proper syntax
void automation_ProcessLead(string leadId) {
    try {
        // Convert ID and fetch record
        recordId = leadId.toLong();
        leadRecord = zoho.crm.getRecordById("Leads", recordId);

        // Null check
        if (!isNull(leadRecord)) {
            // Update logic
            updateMap = Map();
            updateMap.put("Status", "Qualified");

            // Perform update
            response = zoho.crm.updateRecord("Leads", recordId, updateMap);
            info "Lead updated: " + leadId;
        }
    } catch (e) {
        info "Error: " + e;
    }
}

// Standalone function with return
string standalone_GetAccountName(string accountId) {
    try {
        recordId = accountId.toLong();
        accountRecord = zoho.crm.getRecordById("Accounts", recordId);

        if (!isNull(accountRecord)) {
            return accountRecord.get("Account_Name");
        }
    } catch (e) {
        info "Error: " + e;
    }

    return ""; // Fake return
}

